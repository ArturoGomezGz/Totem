# =============================================================================
# Totem — Variables de entorno
# =============================================================================
# Copiar este archivo a .env y completar los valores.
# .env está en .gitignore — nunca committear credenciales reales.
# =============================================================================


# -----------------------------------------------------------------------------
# Base de datos (PostgreSQL / TimescaleDB)
# -----------------------------------------------------------------------------
# Nombre de la base de datos, usuario y contraseña.
# Deben coincidir entre sí — Docker Compose los usa tanto para crear la DB
# como para que la API se conecte a ella.
# En producción usar una contraseña larga y aleatoria.
POSTGRES_DB=totem
POSTGRES_USER=totem
POSTGRES_PASSWORD=changeme


# -----------------------------------------------------------------------------
# MQTT (Mosquitto)
# -----------------------------------------------------------------------------
# Credenciales del cliente MQTT del servidor (el que escucha lecturas y publica
# comandos). Deben coincidir con las definidas en mosquitto/config/mosquitto.conf.
# MQTT_CLIENT_ID identifica al servidor ante el broker — debe ser único.
MQTT_CLIENT_ID=totem-server
MQTT_USERNAME=server
MQTT_PASSWORD=changeme


# -----------------------------------------------------------------------------
# JWT — Autenticación de usuarios
# -----------------------------------------------------------------------------
# Clave secreta usada para firmar y verificar los tokens JWT de la API.
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# Cambiar este valor en cualquier entorno que no sea desarrollo local.
JWT_SECRET=changeme-use-a-long-random-secret-in-production


# -----------------------------------------------------------------------------
# Servidor — URL pública accesible por los ESP32
# -----------------------------------------------------------------------------
# IP o dominio desde el que los dispositivos ESP32 descargan el firmware OTA.
# Debe ser accesible desde la red donde están los ESP32.
# Ejemplos:
#   Red local (RPi o PC):  http://192.168.1.50
#   VPS con dominio:       https://totem.midominio.com
SERVER_URL=http://192.168.1.X


# -----------------------------------------------------------------------------
# Telegram — Bot de notificaciones
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN:
#   Obtener creando un bot con @BotFather en Telegram:
#   1. Abrir @BotFather → /newbot
#   2. Seguir los pasos y copiar el token que entrega
#   Formato: 123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# TELEGRAM_CHAT_ID:
#   ID del chat donde el bot enviará las alertas (tu cuenta personal o un grupo).
#   Cómo obtenerlo:
#   1. Enviar cualquier mensaje al bot
#   2. Abrir en el navegador:
#      https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#   3. Buscar el campo "id" dentro de "chat" en la respuesta JSON
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
